# DeepSeek LLM (必填)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TEMPERATURE=0.0
# 启用 DeepSeek 推理模式（展示思考过程），设为 true 开启
DEEPSEEK_THINKING_ENABLED=false

# Tavily 网络搜索 (必填，用于联网搜索回退)
TAVILY_API_KEY=tvly-your-tavily-api-key

# OpenAI (可选，用于Embeddings代理)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://xiaoai.plus/v1

# Milvus 向量数据库
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=t_collection01

# BGE Embeddings 模型
BGE_MODEL_NAME=BAAI/bge-small-zh-v1.5
BGE_DEVICE=cpu

# API 服务
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=json
# CORS 允许的域名，逗号分隔，"*" 表示允许所有
CORS_ORIGINS=*

# 会话管理
SESSION_TTL_SECONDS=3600
MAX_HISTORY_TURNS=10

# JWT 密钥 (生产环境请更换为随机字符串)
AUTH_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_32_CHARS_MIN